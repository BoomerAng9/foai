# Taskade sync worker — env template. Real values from openclaw vault.
# Mirrors the canonical token names from Stripe / Mercury (MixedCase in vault,
# UPPERCASE in container).

# Neon Postgres (foai.audit_ledger + foai.coaching_notes — Track B #93)
# Use a service-account role with SELECT on foai.audit_ledger and UPDATE only
# on the synced_to_taskade_at column.
NEON_DATABASE_URL=<openclaw:Neon_FOAI_Audit_Ledger_URL>

# Taskade adapter — service-to-service bearer
TASKADE_ADAPTER_URL=http://taskade-adapter:8000
TASKADE_ADAPTER_BEARER=<openclaw:Taskade_Adapter_Inbound_Bearer>

# Workspace + folder for the mirror destination (capture after SAML setup)
TASKADE_DEFAULT_WORKSPACE_ID=<workspace_id_for_The_Future_of_AI>
TASKADE_AUDIT_LEDGER_FOLDER_ID=<folder_id_for_audit-ledger-mirror>

# 32-byte salt for customer-UID SHA-256 hashing (Sacred Separation)
TASKADE_PII_SALT=<openclaw:Taskade_PII_Salt>

# Polling cadence + failure thresholds
SYNC_INTERVAL_SECONDS=300
MAX_CONSECUTIVE_FAILURES=5

# Telegram fallback notifier (Chicken Hawk notifier endpoint)
CHICKEN_HAWK_NOTIFIER_URL=http://hawk-gateway:8000/api/internal/notify
CHICKEN_HAWK_NOTIFIER_BEARER=<openclaw:Chicken_Hawk_Notifier_Bearer>

# Worker behavior
SACRED_SEPARATION_SURFACE=client_tier
LOG_LEVEL=info

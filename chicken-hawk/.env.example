# =============================================================================
# Chicken Hawk — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenClaw Gateway (VPS-1)
# -----------------------------------------------------------------------------
OPENCLAW_API_KEY=your-openclaw-api-key
OPENCLAW_BASE_URL=https://your-openclaw-instance.example.com

# Gateway host/port exposed by the Chicken Hawk orchestrator
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Secret used to sign inter-service JWT tokens
GATEWAY_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed CORS origins (leave blank to allow all — not for production)
# CORS_ALLOW_ORIGINS=https://your-domain.example.com,https://clawx.your-domain.example.com

# -----------------------------------------------------------------------------
# LLM Provider (used by the gateway for intent classification)
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai          # openai | anthropic | ollama
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# PostgreSQL (shared database for all Lil_Hawks)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=chickenhawk
POSTGRES_USER=chickenhawk
POSTGRES_PASSWORD=change-me-secure-password

# Full DSN (constructed automatically; override if needed)
# DATABASE_URL=postgresql://chickenhawk:password@postgres:5432/chickenhawk

# -----------------------------------------------------------------------------
# Lil_Hawk Fleet — Internal Endpoints (VPS-2 Docker network)
# Override only if you change port mappings in docker-compose.yml
# -----------------------------------------------------------------------------
TRAE_HAWK_URL=http://trae-hawk:7001
CODING_HAWK_URL=http://coding-hawk:7002
AGENT_HAWK_URL=http://agent-hawk:7003
FLOW_HAWK_URL=http://flow-hawk:5678
SAND_HAWK_URL=http://sand-hawk:7005
MEMORY_HAWK_URL=http://memory-hawk:7006
GRAPH_HAWK_URL=http://graph-hawk:7007
BACK_HAWK_URL=http://back-hawk:7008
VIZ_HAWK_URL=http://viz-hawk:7009
BLEND_HAWK_URL=http://blend-hawk:7011
DEEP_HAWK_URL=http://deep-hawk:7010

# -----------------------------------------------------------------------------
# Tailscale (remote access)
# -----------------------------------------------------------------------------
TAILSCALE_AUTH_KEY=tskey-auth-...

# -----------------------------------------------------------------------------
# SimStudio (Lil_Viz_Hawk monitoring UI)
# -----------------------------------------------------------------------------
SIMSTUDIO_PORT=3001

# -----------------------------------------------------------------------------
# n8n (Lil_Flow_Hawk)
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-n8n-password
N8N_ENCRYPTION_KEY=change-me-n8n-encryption-key

# -----------------------------------------------------------------------------
# CoPaw / ReMe (Lil_Memory_Hawk)
# -----------------------------------------------------------------------------
COPAW_API_KEY=your-copaw-api-key

# -----------------------------------------------------------------------------
# InsForge (Lil_Back_Hawk)
# -----------------------------------------------------------------------------
INSFORGE_API_KEY=your-insforge-api-key

# -----------------------------------------------------------------------------
# NemoClaw Policy Gate (Wave 1, ecosystem-wide)
# Enterprise-OpenClaw safety variant. Embedded module exposed at /check,
# /risk-event, /risk-events. Bearer-gated for service-to-service.
# -----------------------------------------------------------------------------
NEMOCLAW_API_KEY=change-me-to-32-byte-hex
NEMOCLAW_DATA_DIR=/data/nemoclaw

# -----------------------------------------------------------------------------
# Magic-link Auth (Wave 1, ecosystem-wide)
# Single-owner JWT. Magic link delivered via Telegram bot.
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-32-byte-hex
OWNER_EMAIL=asg@achievemor.io
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-owner-telegram-chat-id
PORTAL_BASE=https://hawk.foai.cloud

# -----------------------------------------------------------------------------
# Hermes Agent — INBOUND owner command surface (Wave 1 Step C, Path 1)
# Hermes Agent (NousResearch) runs on aims-vps as the owner's chat-side
# control plane. Owner chats Telegram/Slack/Discord → Hermes invokes
# chicken-hawk's /run, /check, /audit/{id} as registered tools.
# This is INBOUND (Hermes calls chicken-hawk), not outbound (chicken-hawk
# does NOT call Hermes). No env vars needed on the chicken-hawk side —
# Hermes auths to chicken-hawk using the existing CHICKEN_HAWK_BEARER.
# Magic-link login stays on direct Telegram (TELEGRAM_BOT_TOKEN above).
# Wave 2 will fill in gateway/notifier.py for outbound multi-channel pings.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Squad Backend (Wave 1 Step G)
# Selects the multi-Lil_Hawk fan-out backend used by /chat squad missions.
#   asyncio    — default; raw asyncio.gather() over per-sub-task coroutines
#   agentscope — wraps coros in AgentScope MsgHub for typed messages +
#                future middleware hooks. Falls back to asyncio on import
#                or runtime error.
# -----------------------------------------------------------------------------
SQUAD_BACKEND=asyncio

# -----------------------------------------------------------------------------
# Logging & Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
TRACE_ENABLED=true

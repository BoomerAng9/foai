# Hawk3D Environment Configuration
# Copy this to .env.local and update values

# Chicken-Hawk Gateway Connection
NEXT_PUBLIC_GATEWAY_HOST=localhost
NEXT_PUBLIC_GATEWAY_PORT=3100

# Simulation mode (true = demo data, false = live gateway)
NEXT_PUBLIC_SIMULATION_MODE=true

# Feature flags
NEXT_PUBLIC_ENABLE_VR=false
NEXT_PUBLIC_ENABLE_GLOBE=false
NEXT_PUBLIC_ENABLE_VOICE=false

# Chicken Hawk gateway env template. Real values from openclaw vault.
# Most existing env vars are owned by `config.get_settings()`; this file
# documents the audit_ledger wiring added in Track B Phase 2 (2026-05-15).

# ─── Audit ledger (Track B Phase 2) ────────────────────────────────────────
# Neon Postgres URL for foai.audit_ledger durable backing. When unset, the
# gateway runs on the in-memory _RUN_LEDGER only (fail-closed degradation —
# no regression to /run / /audit/{task_id} behavior).
FOAI_AUDIT_LEDGER_URL=<openclaw:FOAI_Neon_Audit_Ledger_URL>

# Fallback: shared NEON_DATABASE_URL used by the Phase 5 sync worker. The
# writer library picks this up automatically if FOAI_AUDIT_LEDGER_URL is
# unset.
NEON_DATABASE_URL=<openclaw:Neon_FOAI_Audit_Ledger_URL>

# 32-byte random salt for SHA-256 hashing of customer_uid values before
# they hit the audit ledger. EMPTY = writer refuses to write raw UIDs
# (fail-closed). Use the same salt as TASKADE_PII_SALT so Taskade sync can
# correlate hashed UIDs across the mirror.
FOAI_PII_SALT=<openclaw:FOAI_PII_Salt>

# Fallback: shared TASKADE_PII_SALT during env-name migration.
TASKADE_PII_SALT=<openclaw:Taskade_PII_Salt>

# ─── Owner-action checklist before production enablement ──────────────────
# 1. Mint FOAI_PII_Salt + FOAI_Neon_Audit_Ledger_URL in openclaw vault
# 2. Apply schema/audit_ledger.sql to the target Neon instance
# 3. Create foai_writer role with INSERT-only grant on foai.audit_ledger
# 4. Update myclaw-vps gateway docker-compose with the env passthrough
# 5. Restart chicken-hawk-hawk-gateway-1; verify /audit/recent returns 200

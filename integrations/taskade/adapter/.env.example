# Taskade adapter env template — PLACEHOLDERS ONLY, never commit real values.
# Real values live in openclaw vault (MixedCase) and are piped to the
# container as UPPERCASE per the Stripe / Mercury env var canon
# (see ~/.claude/projects/.../memory/reference_stripe_env_var_canon_2026_05_11.md +
# reference_mercury_env_var_canon_2026_05_11.md).

# Taskade auth — Org admin scope (existing Deploy token)
TASKADE_API_KEY=<openclaw:Taskade_Deploy_API_Token>

# Service-account scope (new — Phase 3, owner mints in Taskade Settings > API)
TASKADE_SYNC_TOKEN=<openclaw:Taskade_Sync_Service_Token>

# 32-byte random per-deployment salt for SHA-256 hashing of customer UIDs
# before they leave the FOAI perimeter (Sacred Separation enforcement).
TASKADE_PII_SALT=<openclaw:Taskade_PII_Salt>

# Adapter inbound bearer secret — Chicken Hawk gateway passes this on every
# /invoke call. Rotates independently of Taskade tokens.
ADAPTER_BEARER_SECRET=<openclaw:Taskade_Adapter_Inbound_Bearer>

# Taskade REST base URL (override only for test/sandbox)
TASKADE_API_BASE=https://www.taskade.com/api/v1

# Canonical workspace + folder IDs (captured after SAML setup in Phase 2)
TASKADE_DEFAULT_WORKSPACE_ID=<workspace_id_for_The_Future_of_AI>
TASKADE_AUDIT_LEDGER_FOLDER_ID=<folder_id_for_audit-ledger-mirror>
TASKADE_HRPMO_FOLDER_ID=<folder_id_for_hrpmo-cycles>

# Adapter service config
ADAPTER_PORT=8000
LOG_LEVEL=info

# Default rendering surface for audit_event.render_html.
# - "owner_tier" shows raw agent names (for owner-only surfaces)
# - "client_tier" maps agent names to role descriptors (Sacred Separation)
# Sync worker overrides per-call based on the destination project.
SACRED_SEPARATION_SURFACE_DEFAULT=client_tier

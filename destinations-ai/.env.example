# Destinations AI — environment template
# Copy to .env.local for local dev; set in Cloud Run env for production.
# NEVER commit a populated .env file. Follow foai secret-handling rules.

# ═══════════════════════════════════════════════════════════
# Database — Neon Postgres
# ═══════════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:password@host.neon.tech/destinations?sslmode=require

# ═══════════════════════════════════════════════════════════
# Firebase (auth + admin)
# ═══════════════════════════════════════════════════════════
# Client (public — exposed to browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin (server-only — match perform convention: discrete env vars)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Private key: newlines escaped as \n in env storage; runtime unescapes.
FIREBASE_PRIVATE_KEY=

# ═══════════════════════════════════════════════════════════
# Google Cloud / Vertex AI (Gemini for intention ranking)
# ═══════════════════════════════════════════════════════════
GOOGLE_CLOUD_PROJECT=ai-managed-services
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Model IDs — update to current latest per foai standing rule
VERTEX_GEMINI_MODEL=gemini-2.5-pro
VERTEX_GEMINI_FLASH_MODEL=gemini-2.5-flash

# ═══════════════════════════════════════════════════════════
# Maps
# ═══════════════════════════════════════════════════════════
# Which provider to use: 'maplibre' (default, free tier) or 'google3d' (photorealistic)
NEXT_PUBLIC_MAP_PROVIDER=maplibre

# MapLibre — MapTiler vector tiles (recommended)
NEXT_PUBLIC_MAPTILER_KEY=

# Google Maps Platform — Photorealistic 3D Tiles + Places
# Requires Maps 3D, Map Tiles, and Places APIs enabled on the key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ═══════════════════════════════════════════════════════════
# Observability (Phase 2)
# ═══════════════════════════════════════════════════════════
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=

# ═══════════════════════════════════════════════════════════
# Feature flags
# ═══════════════════════════════════════════════════════════
# Expose /dev/tweaks visual dev panel (never enable in prod)
NEXT_PUBLIC_ENABLE_TWEAKS=false

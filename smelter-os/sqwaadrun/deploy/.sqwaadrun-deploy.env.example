# ═══════════════════════════════════════════════════════════════════
#  Sqwaadrun Master Deploy — environment template
# ═══════════════════════════════════════════════════════════════════
#
# Copy to ~/.sqwaadrun-deploy.env and fill in the real values.
# The master deploy script sources this before running.
#
#   cp deploy/.sqwaadrun-deploy.env.example ~/.sqwaadrun-deploy.env
#   chmod 600 ~/.sqwaadrun-deploy.env
#   # edit with your real values
#   ./deploy/deploy-master.sh
#
# Never commit a real copy of this file to git.
# ═══════════════════════════════════════════════════════════════════

# ─── SSH targets ───
# Hostinger VPS — where Puter runs (Smelter OS native storage host)
HOSTINGER_SSH_HOST=deploy@hostinger.ip.or.hostname

# myclaw-vps — where cti-hub container serves deploy.foai.cloud
MYCLAW_SSH_HOST=deploy@myclaw.ip.or.hostname
CTI_HUB_PATH=/opt/cti-hub

# ─── GCP project ───
GCP_PROJECT=foai-aims
GCP_REGION=us-east4
GCP_ZONE=us-east4-a

# ─── Neon Postgres (structured data) ───
# The public schema DSN — used for profile column migration + read queries
NEON_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.neon.tech/foai?sslmode=require

# The sqwaadrun_staging ingest DSN — separate role with write access to
# the staging schema and nothing else
NEON_INGEST_DSN=postgresql://sqwaadrun_ingest:PASSWORD@ep-xxxx.neon.tech/foai?sslmode=require

# ─── Stripe ───
# Secret key from the Stripe dashboard. Test mode = sk_test_...,
# live mode = sk_live_...
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# ─── Optional — auto-generated if omitted ───
# Leave blank to have deploy-master.sh generate a fresh 32-byte hex
# SQWAADRUN_API_KEY=
# PUTER_API_KEY=

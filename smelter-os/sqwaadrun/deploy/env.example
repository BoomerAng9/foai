# Place at /etc/sqwaadrun/env on the VM. Pull real values from
# Secret Manager via gcloud:
#   gcloud secrets versions access latest --secret=NEON_INGEST_DSN
#
# Permissions: chmod 600, owned by root.

# ── Gateway auth (clients send this as Bearer token) ──
SQWAADRUN_API_KEY=replace_me_with_a_long_random_string

# ── Neon DB for staging writes ──
NEON_INGEST_DSN=postgresql://sqwaadrun_ingest:PASSWORD@host.neon.tech/foai?sslmode=require

# ── Quotas ──
SQWAADRUN_QUOTA_PER_DOMAIN=2000
SQWAADRUN_SIGNOFF_THRESHOLD=200

# ── Persistence ──
SQWAADRUN_DATA_DIR=/var/lib/sqwaadrun

# ── Logging ──
PYTHONUNBUFFERED=1
PYTHONIOENCODING=utf-8
PYTHONUTF8=1

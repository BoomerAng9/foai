# ═══════════════════════════════════════════════════════════════════
#  Sqwaadrun Gateway environment file
# ═══════════════════════════════════════════════════════════════════
# Place at /etc/sqwaadrun/env on the VM. Pull real values from
# Secret Manager via gcloud:
#   gcloud secrets versions access latest --secret=NEON_INGEST_DSN
#
# Permissions: chmod 600, owned by root.

# ─── Gateway auth (clients send this as Bearer token) ───
SQWAADRUN_API_KEY=replace_me_with_a_long_random_string

# ─── Neon Postgres (structured data) ───
NEON_INGEST_DSN=postgresql://sqwaadrun_ingest:PASSWORD@host.neon.tech/foai?sslmode=require
NEON_DATABASE_URL=postgresql://readonly:PASSWORD@host.neon.tech/foai?sslmode=require

# ─── Puter (Smelter OS native storage) ───
# Self-hosted Puter container on the internal Docker network
PUTER_BASE_URL=http://smelter-puter:4100
PUTER_API_KEY=replace_with_puter_bearer_token

# ─── GCS (scalable artifact storage) ───
GCP_PROJECT_ID=foai-aims
# GOOGLE_APPLICATION_CREDENTIALS unset on GCE — uses attached service account
GCS_ARTIFACTS_BUCKET=foai-sqwaadrun-artifacts
GCS_INGOTS_BUCKET=foai-ingots
GCS_MEDIA_BUCKET=foai-media
GCS_BACKUPS_BUCKET=foai-backups

# ─── Quotas ───
SQWAADRUN_QUOTA_PER_DOMAIN=2000
SQWAADRUN_SIGNOFF_THRESHOLD=200

# ─── Persistence ───
SQWAADRUN_DATA_DIR=/var/lib/sqwaadrun

# ─── Heartbeat cadence (Chronicle Ledger writes to Puter) ───
SQWAADRUN_HEARTBEAT_INTERVAL_SECONDS=90

# ─── TRCC pipeline (set to 1 to disable the data factory) ───
# SQWAADRUN_DISABLE_TRCC=0

# ─── Logging ───
PYTHONUNBUFFERED=1
PYTHONIOENCODING=utf-8
PYTHONUTF8=1

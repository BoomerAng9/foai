# ─── Firebase Auth (required) ─────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=foai
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Firebase Admin (server-side, from GCP Secret Manager) ──
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ─── Neon Postgres (required) ─────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/grammar?sslmode=require

# ─── Stripe (required for payments) ─────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_...

# ─── LLM API Keys (OpenRouter only) ─────────────
# All model calls route through OpenRouter. No direct Anthropic/OpenAI keys.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_KEY=sk-or-...
OPENROUTER_TEXT_MODEL=google/gemini-3.1-flash
OPENROUTER_VOICE_MODEL=google/gemini-3.1-flash
NEXT_PUBLIC_OPENROUTER_TEXT_MODEL=google/gemini-3.1-flash
NEXT_PUBLIC_OPENROUTER_VOICE_MODEL=google/gemini-3.1-flash
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=optional-default-elevenlabs-voice-id
ELEVENLABS_MODEL_ID=optional-premium-elevenlabs-model-id
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
GROK_VOICE_API_KEY=your-xai-api-key
GROK_VOICE_ENDPOINT=https://api.x.ai/v1/audio/speech
GROK_VOICE_MODEL=optional-grok-voice-model
GROK_VOICE_VOICE=optional-grok-voice-id
NVIDIA_PERSONAPLEX_API_KEY=your-nvidia-api-key
NVIDIA_PERSONAPLEX_ENDPOINT=https://integrate.api.nvidia.com/v1/audio/speech
NVIDIA_PERSONAPLEX_MODEL=optional-nvidia-voice-model
NVIDIA_PERSONAPLEX_VOICE=optional-nvidia-voice-id

# ─── NotebookLM / Discovery Engine ──────────────
GCP_PROJECT_ID=foai-aims
NOTEBOOKLM_LOCATION=global
NOTEBOOKLM_ACCESS_TOKEN=ya29...
NOTEBOOKLM_API_KEY=optional-fallback-api-key

# ─── Auth ────────────────────────────────────────
JWT_SECRET=generate-a-random-256-bit-key
JWT_REFRESH_SECRET=generate-another-random-256-bit-key

# ─── Encryption ─────────────────────────────────
CREDS_KEY=generate-a-32-byte-hex-key
CREDS_IV=generate-a-16-byte-hex-iv

# ─── App Config ─────────────────────────────────
HOST=localhost
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

# ─── Channel webhooks / adapters ───────────────
CHANNELS_WEBHOOK_SECRET=generate-a-random-shared-secret
WHATSAPP_VERIFY_TOKEN=optional-whatsapp-verify-token
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
GMAIL_OAUTH_TOKEN=
WHATSAPP_API_KEY=

# ─── Visual Engine ───
# Primary character-portrait adapter
RECRAFT_API_KEY=
# Fallback 1 — character reference mode
IDEOGRAM_API_KEY=
# Stub adapters (wire when Sub-project #3 or follow-up spec demands)
FAL_API_KEY=
KIE_API_KEY=
# Vertex stubs — ADC in dev, Cloud Run binding in prod, see spec §12
# VERTEX_PROJECT_ID=foai-aims
# VERTEX_LOCATION=us-central1

# ─── Inworld (Spinner function calling + Realtime voice) ─────
# Required for /api/spinner/chat and any Spinner-backed surface.
# Missing key causes routes to return 503 with a fallback message.
INWORLD_API_KEY=
# Optional overrides — leave blank for defaults.
# INWORLD_BASE_URL=https://api.inworld.ai/v1
# INWORLD_REALTIME_URL=wss://api.inworld.ai/api/v1/realtime/session
# PORT_AUTHORITY_URL=http://localhost:3000/api

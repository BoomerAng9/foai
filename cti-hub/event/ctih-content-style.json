        "note": "Always capitalize Hack-A-Thon with hyphens"
      },
      "brand_voice": {
        "tone": "energetic, inclusive, professional, forward-thinking",
        "avoid": ["exclusive", "elite", "limited spots (unless true)", "game-changer"],
        "preferred_terms": {
          "participants": "innovators",
          "projects": "solutions",
          "competition": "challenge",
          "networking": "connecting"
        }
      },
      "sponsor_communications": {
        "tone": "professional, ROI-focused, partnership-oriented",
        "always_include": "value proposition and expected outcomes"
      }
    }
  }
}

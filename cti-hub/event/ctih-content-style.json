{
  "event": {
    "name": "Coastal Talent and Innovation Hack-A-Thon",
    "shortCode": "CTIH"
  },
  "grammar_role": {
    "description": "GRAMMAR engine ensures all CTIH event communications maintain consistent brand voice, proper terminology, and professional quality across marketing, emails, and social posts.",
    "style_rules": {
      "event_name": {
        "full": "Coastal Talent and Innovation Hack-A-Thon",
        "short": "CTIH",

version: 1.3.6
cache: true

interface:
  customWelcome: "Chat w/ACHEEVY"
  endpointsMenu: true
  modelSelect: true
  presets: true
  parameters: true

endpoints:
  custom:
    - name: "Chat w/ACHEEVY (OpenRouter)"
      apiKey: "${OPENAI_API_KEY}"
      baseURL: "https://openrouter.ai/api/v1"
      models:
        default:
          - "openai/gpt-4o-mini"
          - "anthropic/claude-3.5-sonnet"
          - "google/gemini-2.0-flash-001"
          - "openai/gpt-4.1-mini"
        fetch: false
      titleConvo: true
      titleModel: "openai/gpt-4o-mini"
      summarize: false
      modelDisplayLabel: "OpenRouter"

{
  "name": "@aims/spinner",
  "version": "0.1.0",
  "description": "Spinner — A.I.M.S. autonomous chat-execution feature. Listens via RFP-BAMARAM intent detection, executes in background, surfaces in PiP / Live Look In. Available across Deploy, AIMS, CTI Hub, Per|Form, SmelterOS. Inspired by Genspark's Speakly but built independently — we do NOT use Genspark code or branding.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./intent": "./src/intent-classifier.ts",
    "./engine": "./src/chat-engine.ts",
    "./sidecar": "./src/sidecar.ts",
    "./worker": "./src/background-worker.ts",
    "./live-look-in": "./src/live-look-in.ts",
    "./consultant": "./src/three-consultant-engagement.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@aims/pricing-matrix": "*",
    "@aims/pmo": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "private": true
}

{
  "name": "@aims/spinner",
  "version": "0.2.0",
  "description": "Spinner — A.I.M.S. autonomous chat-execution feature. Listens via RFP-BAMARAM intent detection, executes in background, surfaces in PiP / Live Look In. Runs function-calling over Inworld LLM Router and duplex voice over Inworld Realtime WS. Available across Deploy, AIMS, CTI Hub, Per|Form, SmelterOS. Inspired by Genspark's Speakly but built independently — we do NOT use Genspark code or branding.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./intent": "./src/intent-classifier.ts",
    "./engine": "./src/chat-engine.ts",
    "./sidecar": "./src/sidecar.ts",
    "./worker": "./src/background-worker.ts",
    "./live-look-in": "./src/live-look-in.ts",
    "./consultant": "./src/three-consultant-engagement.ts",
    "./inworld": "./src/inworld-client.ts",
    "./realtime": "./src/inworld-realtime.ts",
    "./tool-registry": "./src/tool-registry.ts",
    "./function-calling": "./src/function-calling.ts",
    "./tools/port-authority": "./src/tools/port-authority.ts",
    "./chat-route": "./src/chat-route-helper.ts",
    "./orchestration": "./src/orchestration-schema.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test src/__tests__/*.test.ts",
    "smoke:chat": "node --experimental-strip-types scripts/smoke-test-chat.ts"
  },
  "dependencies": {
    "@aims/pricing-matrix": "file:../aims-pricing-matrix",
    "@aims/pmo": "file:../aims-pmo",
    "zod": "^3.23.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.0"
  },
  "private": true
}

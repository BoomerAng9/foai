# Per|Form — environment variables (SHIP-CHECKLIST G1.2)
#
# Copy this file to .env.local and fill in real values. Every variable
# the code reads (via process.env.*) is documented here with its source
# of truth + purpose. Keep this file current: any new process.env.X added
# to src/ or scripts/ MUST show up here before PR merge (G1.2 regression).
#
# Last regenerated: 2026-04-21
# Source of truth for keys in production: GCP Secret Manager + VPS env

# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
ADMIN_EMAIL=you@example.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
PERFORM_BASE_URL=http://localhost:3000

# ── Database (Neon Postgres) ─────────────────────────────────────────
DATABASE_URL=postgres://USER:PASS@HOST:5432/perform?sslmode=require

# ── Auth / Sessions ──────────────────────────────────────────────────
PIPELINE_AUTH_KEY=change-me-for-production
WEBHOOK_SECRET=change-me-for-production

# ── AI / LLM providers ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_API_KEY=AIza...
GEMINI_VIZ_MODEL=gemini-2.5-flash

# ── Voice / Speech ───────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
SCRIBE_MODEL_ID=

# ── Image generation (per Iller_Ang canonical routing) ───────────────
RECRAFT_API_KEY=
IDEOGRAM_API_KEY=
FAL_API_KEY=
FAL_KEY=          # alias used by fal.ai SDK in some call sites
KIE_AI_API_KEY=
LYRIA_API_KEY=

# ── Video / HeyGen / Lip-sync ────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_WEBHOOK_SECRET=
TWELVE_LABS_API_KEY=

# ── GCP (Vertex AI, Cloud Storage, Cloud Run) ────────────────────────
GCP_PROJECT_ID=foai-aims
GCP_LOCATION=us-central1
GOOGLE_KEY=                               # GCP service-account key content
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-sa.json

# ── Firebase (auth + hosting) ────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── Email / Comms ────────────────────────────────────────────────────
RESEND_API_KEY=
PRODUCER_FROM_EMAIL=producer@example.com

# ── Payments (Stripe) — G4 Can Someone Pay? ──────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SINGLE=price_...
STRIPE_PRICE_PACK=price_...
STRIPE_PRICE_UNLIMITED=price_...
STRIPE_PRICE_WAR_ROOM=price_...

# ── Data sources ─────────────────────────────────────────────────────
CFBD_API_KEY=                             # CollegeFootballData
BRAVE_API_KEY=                            # Brave Search API
X_BEARER_TOKEN=                           # X (Twitter) bearer

# ── Sqwaadrun integration ────────────────────────────────────────────
SQWAADRUN_API_KEY=
SQWAADRUN_GATEWAY_URL=https://sqwaadrun-foai-aims.a.run.app

# ── Stitch / external tools ──────────────────────────────────────────
STITCH_API_KEY=
STITCH_MCP_URL=
C1_API_KEY=
C1_BASE_URL=
C1_MODEL=

# ── Paperform (legacy, pending retirement) ───────────────────────────
PAPERFORM_ACCESS_TOKEN=

# ── Misc ─────────────────────────────────────────────────────────────
ASYNC_API_KEY=
ML_SERVICE_URL=
VERCEL_URL=                               # set automatically on Vercel

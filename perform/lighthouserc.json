{
  "ci": {
    "collect": {
      "url": [
        "https://perform.foai.cloud/",
        "https://perform.foai.cloud/login",
        "https://perform.foai.cloud/signup",
        "https://perform.foai.cloud/forgot",
        "https://perform.foai.cloud/rankings"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.70 }],
        "categories:accessibility": ["warn", { "minScore": 0.80 }],
        "categories:best-practices": ["warn", { "minScore": 0.80 }],
        "categories:seo": ["warn", { "minScore": 0.80 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-report"
    }
  }
}

# Per|Form staging env (SHIP-CHECKLIST Gate 5 · Item 30)
#
# Copy to .env.staging on the VPS at /opt/foai-repo/perform/.env.staging
# and fill with the staging-only values. MUST NOT share resources with
# .env.local (prod) — Gate 5 Item 30 requires zero shared resources
# between staging and production.
#
# Rule of thumb: every URL, API key, and bucket here has a distinct value
# from its .env.local counterpart — or the value is safe-to-reuse (e.g.
# model names, feature flags) and explicitly marked as such below.

# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=staging
ADMIN_EMAIL=you@example.com
NEXT_PUBLIC_BASE_URL=https://perform-staging.foai.cloud
PERFORM_BASE_URL=https://perform-staging.foai.cloud
NEXT_PUBLIC_PERFORM_ENV=staging

# ── Database (Neon — SEPARATE BRANCH FROM PROD) ──────────────────────
# Create via: Neon console → performdb project → Branches → Create branch
# from main → name: staging → copy connection string to this line.
DATABASE_URL=postgres://USER:PASS@HOST-pooler.NEON_REGION.aws.neon.tech/performdb?sslmode=require

# ── Auth / Sessions — DIFFERENT SECRETS FROM PROD ────────────────────
PIPELINE_AUTH_KEY=staging-change-me
WEBHOOK_SECRET=staging-change-me

# ── AI / LLM — prod keys OK to reuse (same provider, same billing) ───
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_API_KEY=AIza...

# ── Stripe (TEST MODE ONLY in staging) ───────────────────────────────
# Never use sk_live_* here — staging should fail loud if prod keys leak in.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...
STRIPE_PRICE_SINGLE=price_...
STRIPE_PRICE_PACK=price_...
STRIPE_PRICE_UNLIMITED=price_...
STRIPE_PRICE_WAR_ROOM=price_...

# ── Firebase (separate project recommended, shared acceptable) ───────
# If you want true isolation, create a second Firebase project named
# "foai-aims-staging" and point these there. Shared is fine for Gate 5
# provisional pass; full isolation is a Gate 6 concern.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# ── Stepper (optional — only if testing billing spine) ───────────────
# Use a distinct Taskade workflow for staging so test purchases don't
# trigger the prod notification channels.
STEPPER_URL=
STEPPER_KEY=

# ── Data sources (shared OK — read-only public APIs) ─────────────────
CFBD_API_KEY=
BRAVE_API_KEY=
X_BEARER_TOKEN=

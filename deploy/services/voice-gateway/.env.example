# Environment
NODE_ENV=development
PORT=3002

# Groq (STT via whisper-large-v3)
GROQ_API_KEY=gsk_your_key_here

# Inworld — server-to-server auth (NEVER exposed to the browser)
#
# INWORLD_API_KEY is used for server-side calls only:
#   - voice-clone POST to /tts/v1/voices:clone (this stays on the server)
# It is NEVER sent to the browser. Do NOT reuse it as the realtime session
# token — that was the pre-0.2.0 leak pattern this service replaced.
INWORLD_API_KEY=
INWORLD_REALTIME_WSS=wss://api.inworld.ai/v1/realtime
INWORLD_REALTIME_MODEL=google-ai-studio/gemini-3.1-flash
INWORLD_DEFAULT_VOICE=Dennis
INWORLD_DEFAULT_TTS_MODEL=inworld-tts-1.5-mini
INWORLD_VOICE_CLONE_URL=https://api.inworld.ai/tts/v1/voices:clone

# Inworld Realtime JWT — MUST be set for /v1/spinner/session to mint
# short-lived Bearer tokens the browser can use to connect directly to
# Inworld's Realtime WSS. Obtain the signing secret from the Inworld
# Portal (Settings → JWT signing key). Do NOT reuse INWORLD_API_KEY
# for this — that would recreate the leak.
INWORLD_JWT_SECRET=
INWORLD_JWT_ISSUER=deploy-by-achievemor
INWORLD_JWT_AUDIENCE=inworld-realtime
# TTL in seconds for ephemeral realtime JWTs (default 120, max 600).
INWORLD_JWT_TTL_SECONDS=120

# GCP (optional — for logging)
GCP_PROJECT_ID=deploy-1e2cd

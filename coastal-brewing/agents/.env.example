# Google ADK runtime
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=

# Chicken Hawk gateway (production tool execution)
CHICKEN_HAWK_URL=https://hawk.foai.cloud
CHICKEN_HAWK_BEARER=

# AuditLedger (production receipts; renamed from Hermes 2026-04-26)
AUDIT_LEDGER_DB_URL=sqlite:////app/audit_ledger/coastal_brewing.db
# When migrated to Neon: AUDIT_LEDGER_DB_URL=postgres://user:pass@host.neon.tech/coastal_brewing

# NemoClaw policy gate (embedded in Chicken Hawk; same bearer)
NEMOCLAW_URL=https://hawk.foai.cloud/check

# Coastal-specific
COASTAL_OWNER_TELEGRAM_CHAT_ID=
COASTAL_BREW_BOT_TOKEN=

# Core
COMPANY_NAME="Coastal Brewing"
ENVIRONMENT=development
OWNER_APPROVAL_EMAIL=
COASTAL_GATEWAY_TOKEN=

# NVIDIA model lane
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_FAST=
NVIDIA_MODEL_REASONING=
NVIDIA_MODEL_SECONDARY=

# Premium fallback lane
PREMIUM_MODEL_PROVIDER=
PREMIUM_MODEL_API_KEY=
PREMIUM_MODEL_NAME=

# Feynman lane
FEYNMAN_CLI_PATH=feynman
FEYNMAN_OUTPUT_DIR=research/receipts
FEYNMAN_REQUIRE_CITATIONS=true

# AuditLedger (SQLite for Phase 0; renamed from Hermes 2026-04-26)
DATABASE_URL=sqlite:///audit_ledger/coastal_brewing.db

# Paperclip control plane — owns its own Postgres; does not replace AuditLedger yet
PAPERCLIP_POSTGRES_PASSWORD=
PAPERCLIP_PUBLIC_URL=https://paperclip.foai.cloud
PAPERCLIP_BETTER_AUTH_SECRET=

# Transactional email (Resend). Empty key = sends are skipped + recorded
# as 'skipped' in AuditLedger; system stays functional without faking.
# Get an API key at https://resend.com/api-keys.
RESEND_API_KEY=
# Sender. Defaults to onboarding@resend.dev (works without domain
# verification). Owner can swap to a verified brand domain anytime.
RESEND_FROM=Coastal Brewing <onboarding@resend.dev>
# Where supplier wholesale orders go (defaults to owner approval email).
COASTAL_SUPPLIER_EMAIL=

# Stepper / Taskade — automation surface (replaces n8n)
TASKADE_ACCESS_TOKEN=

# Supplier (default: Temecula Coffee Roasters)
SUPPLIER_NAME=Temecula Coffee Roasters
SUPPLIER_PORTAL_URL=
SUPPLIER_API_KEY=

# Hostinger Ecommerce — future storefront target (placeholder until product launches)
HOSTINGER_ECOMMERCE_API_BASE=
HOSTINGER_ECOMMERCE_API_KEY=
HOSTINGER_ECOMMERCE_STORE_ID=

# Stripe — Option C: runner handles checkout directly
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_COASTAL_COFFEE_SUB_PRICE_ID=
STRIPE_COASTAL_TEA_SUB_PRICE_ID=
STRIPE_COASTAL_COMBO_SUB_PRICE_ID=
COASTAL_PUBLIC_URL=https://brewing.foai.cloud

# NemoClaw — guard layer (now embedded in Chicken Hawk gateway)
NEMOCLAW_URL=https://hawk.foai.cloud
NEMOCLAW_API_KEY=

# Telegram — owner approval delivery (relay from openclaw on myclaw-vps)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# HMAC secret for one-click /approve/click links in Telegram messages (1-week TTL)
COASTAL_APPROVE_SECRET=

# Lil_Hawks dispatch (chicken-hawk + sqwaadrun)
HAWK_GATEWAY_URL=https://hawk.foai.cloud
SQWAADRUN_BASE_URL=https://sqwaadrun.foai.cloud
SQWAADRUN_API_KEY=

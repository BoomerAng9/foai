# ===========================================================================
# ACHEEVY / ii-agent Frontend Environment
# Copy this file to .env.local and fill in the values.
# ===========================================================================

# Backend API base URL (include protocol, no trailing slash)
VITE_API_URL=http://localhost:8000

# Frontend runtime mode for API base URL selection (test, production)
VITE_ACHEEVY_BACKEND_MODE=test

# Socket.IO reuses VITE_API_URL unless you proxy it separately.
# If you later split websocket traffic to a dedicated host, add that var in code first.

# Google OAuth Client ID (from console.cloud.google.com → Credentials)
VITE_GOOGLE_CLIENT_ID=

# Stripe publishable key (from dashboard.stripe.com → Developers → API keys)
VITE_STRIPE_PUBLISHABLE_KEY=

# Sentry DSN for error tracking (from sentry.io → Project Settings → Client Keys)
VITE_SENTRY_DSN=

# Feature flags
# Keep false until a real email/password backend flow is implemented.
VITE_ENABLE_EMAIL_AUTH=false
VITE_DISABLE_CHAT_MODE=false

# Policy debug events (true to show policy-layer diagnostics in chat)
VITE_POLICY_DEBUG_EVENTS=false

# ─── A.I.M.S. Telegram Bridge — environment variables ───────────────────────
# Copy to .env and fill in values. Never commit this file.
#
# Get your bot token from @BotFather on Telegram.
# Get your chat ID by messaging your bot and visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
#   then reading result[0].message.chat.id

TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Internal WireGuard addresses (do not change unless your network changes)
VPS1_URL=http://10.0.0.1:3001
VPS2_URL=http://10.0.0.2:4400

# Public domain
AIMS_DOMAIN=plugmein.cloud

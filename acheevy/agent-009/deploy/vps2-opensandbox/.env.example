# =============================================================================
# A.I.M.S. VPS2 — Environment Variables
# Copy to .env and fill in secrets. Never commit the filled .env file.
# =============================================================================

# ─── WireGuard / networking ──────────────────────────────────────────────────
VPS1_URL=http://10.0.0.1:3001
VPS2_URL=http://10.0.0.2:4400

# ─── OpenSandbox ────────────────────────────────────────────────────────────
SANDBOX_MODE=docker
# OPENAI_API_KEY=sk-...     (optional — only needed if sandbox uses LLM directly)

# ─── Plug Engine ────────────────────────────────────────────────────────────
PLUG_PORT_START=51000
PLUG_PORT_END=51999

# ─── Domains ────────────────────────────────────────────────────────────────
AIMS_DOMAIN=plugmein.cloud
AIMS_LANDING_DOMAIN=aimanagedsolutions.cloud

# ─── Telegram Bridge ────────────────────────────────────────────────────────
# Fill these in after creating your bot with @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE
